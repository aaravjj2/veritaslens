# VeritasLens web app
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (magic-link auth + analysis persistence)
# In Supabase Dashboard → Authentication → URL configuration, add:
#   Site URL: http://localhost:3000 (or your deployed origin)
#   Redirect URLs: http://localhost:3000/auth/callback
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protect POST /api/cron/digest with Authorization: Bearer <secret>
CRON_SECRET=

# Weekly digest email (used by /api/cron/digest when both are set)
RESEND_API_KEY=
RESEND_FROM="VeritasLens <onboarding@resend.dev>"

# HS256 secret for extension panel JWT (min 16 chars). POST /api/extension/token when signed in on web.
EXTENSION_JWT_SECRET=

# Set to 1 to register /public/sw.js in dev (e.g. Playwright offline tests)
# NEXT_PUBLIC_ENABLE_SW=
